{
  "name": "cypress",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "cypress:run:chrome": "cypress run --browser chrome",
    "cypress:run:headed": "cypress run --browser chrome --headed",
    "cypress:run:chrome:dev:headed": "cypress run --browser chrome --headed --env TEST_ENV=dev",
    "cypress:run:chrome:prod:headed": "cypress run --browser chrome --headed --env TEST_ENV=prod",
    "cypress:run:hw21:prod": "cypress run --browser chrome --headed --env TEST_ENV=prod --spec \"cypress/e2e/qaauto-hw21.test.js\"",
    "cypress:run:hw21:dev": "cypress run --browser chrome --headed --env TEST_ENV=dev --spec \"cypress/e2e/qaauto-hw21.test.js\"",
    "merge-reports": "mochawesome-merge cypress/reports/.jsons/*.json > cypress/reports/final-report.json",
    "generate-report": "npx marge cypress/reports/final-report.json -o cypress/reports/html"
  },
  "dependencies": {
    "cypress": "^15.17.0"
  },
  "devDependencies": {
    "cypress-mochawesome-reporter": "^4.0.2"
  }
}
